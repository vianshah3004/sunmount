{
  "name": "inventory-module",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:unified": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:hardening": "tsx src/scripts/runProductionDataMigration.ts",
    "db:migrate:verify": "tsx src/scripts/verifyProductionDataMigration.ts --fail-on-issues",
    "db:migrate:verify:report": "tsx src/scripts/verifyProductionDataMigration.ts --fail-on-issues --report=./reports/migration-verification.json",
    "seed": "tsx seedDatabase.ts",
    "test:performance": "tsx performanceTest.ts",
    "test:hardening": "AUTH_ENABLED=true tsx testHardening.ts",
    "test:inventory": "tsx testInventory.ts",
    "test:inventory:tsnode": "ts-node testInventory.ts",
    "test:system": "tsx testSystem.ts",
    "test:socket": "tsx testSocket.ts",
    "qa:e2e": "AUTH_ENABLED=true tsx qa/runE2EValidation.ts",
    "qa:concurrency": "AUTH_ENABLED=true tsx qa/concurrencyProbe.ts",
    "qa:failure": "tsx qa/failureProbe.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "fast-csv": "^5.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.30.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
